.row.justify-content-center
  .form-box
    - unless @error
      %h1 Create a Team
      %hr
      %br
      = simple_form_for @team, url: :event_teams do |form|
        .my-2
          = form.input :name, label: 'Name:'
        .my-2
          = form.input :image, label: "Icon", error: "The file must be an image"
        .my-2
          = form.input :brief
          %p.text-muted.small.mb-0 Or generate the brief from a published Google Doc:
          = form.input :brief_url, label: false, placeholder: 'https://docs.google.com/document/d/e/…/pub',
            hint: 'In Google Docs: File → Share → Publish to web, then paste the link here. This overrides any uploaded file.'

        .form-actions
          = form.button :submit, class: 'btn generic-button-success'

    - else
      %h2
        Error!
      %p
        = @error
