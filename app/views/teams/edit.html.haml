.row.justify-content-center
  .col-sm-8.mw-75
    - unless @error
      .card
        %h1.card-header
          = "Editing Team #{@team.name}" 
        = simple_form_for @team, url: :event_team, method: :put do |form|
          .card-body
            = form.input :name
            %p
            = form.input :image, label: "Icon", error: "The file must be an image"
            %p
            = form.input :brief
            %p.text-muted.small.mb-0 Or generate the brief from a published Google Doc:
            = form.input :brief_url, label: false, placeholder: 'https://docs.google.com/document/d/e/…/pub',
              hint: 'In Google Docs: File → Share → Publish to web, then paste the link here. This overrides any uploaded file.'
            %p.text-muted.small Uploading a new file replaces the current one; leave a field blank to keep it.
          .card-footer.d-flex
            = form.button :submit, "Save", class: 'btn generic-button-success', method: :get
    - else
      %h2
        Error!
      %p
        = @error
